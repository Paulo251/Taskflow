<%= form_with model: task do |form| %>
  <div class="flex flex-col mt-4">
    <%= form.label :title, "Título" %>
    <%= form.text_field :title, class: "text-slate-700 bg-gray-50 rounded border mt-1" %>
  </div>

  <div class="flex flex-col mt-4">
    <%= form.label :description, "Descrição" %>
    <%= form.text_field :description, class: "text-slate-700 bg-gray-50 rounded border mt-1" %>
  </div>

  <div class="flex justify-end mt-8">
    <%= form.submit  task.persisted? ? "Salvar alterações" : "Criar task", class: "rounded-xl bg-blue-600 px-4 py-2 hover:bg-blue-800 hover:cursor-pointer" %>
  </div>
<% end %>
