# ─────────────────────────────────────────────────────────────
# Taskflow — environment variables
# Copy this file to `.env` and adjust the values for your machine:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Host user/group IDs used to run the app container.
# Keeps files created inside the container owned by your host user
# (avoids permission issues on the mounted volume).
# On Linux, get yours with:  id -u   and   id -g
MY_UID=1000
GID=1000

# PostgreSQL credentials (used by the `db` service)
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow
POSTGRES_DB=taskflow_development

# Rails
RAILS_ENV=development

# Full database connection string used by the Rails app.
# Host `db` matches the docker-compose service name.
DATABASE_URL=postgresql://taskflow:taskflow@db/taskflow_development
